DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public"
JWT_SECRET="change-this-to-a-long-random-secret"
NODE_ENV="production"
PORT="4000"

# Comma-separated frontend origins allowed to call the API.
CORS_ORIGINS="https://your-vercel-app.vercel.app"

# Optional, enables AI itinerary summaries.
OPENAI_API_KEY=""

# Optional, recommended for shared cache in production.
REDIS_URL=""

# Optional, recommended for permanent object storage.
# Without these, uploaded images are stored as data URLs in the database.
S3_BUCKET=""
S3_REGION=""
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""
S3_ENDPOINT=""
S3_PUBLIC_URL=""
